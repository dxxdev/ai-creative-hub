# ---- App ----
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# ---- Database (PostgreSQL) ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_creative_hub?schema=public"

# ---- Redis (sessions cache, rate-limit, BullMQ) ----
REDIS_URL="redis://localhost:6379"

# ---- JWT ----
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES_IN="30d"

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/auth/oauth/google/callback"

# ---- Mail (transactional email, e.g. Resend / SMTP) ----
MAIL_FROM="AI Creative Hub <no-reply@ai-creative-hub.dev>"
MAIL_PROVIDER="console" # console | resend | smtp
RESEND_API_KEY=""

# ---- Cloudflare R2 (media storage, used from Sprint 2 onward) ----
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""