// AI Creative Hub — Prisma Schema v1
// Sprint 1 scope: User, Account, Session, Profile (autentifikatsiya uchun poydevor).
// Post, Prompt, Tag, Like, Comment, Collection va h.k. keyingi sprintlarda shu faylga qo'shiladi.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  VERIFIED_CREATOR
  MODERATOR
  ADMIN
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  BANNED
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  username     String?    @unique
  passwordHash String? // OAuth-only foydalanuvchilarda null (PRD 1.3.2)
  role         UserRole   @default(USER)
  status       UserStatus @default(PENDING_VERIFICATION)

  accounts            Account[]
  sessions            Session[]
  profile             Profile?
  passwordResetTokens PasswordResetToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("users")
}

/// Har bir login usuli (credentials, google, ...) uchun alohida yozuv.
/// Bitta User bir nechta Account'ga ega bo'lishi mumkin (PRD 1.3.2, band 3).
model Account {
  id                String       @id @default(uuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          AuthProvider
  providerAccountId String // credentials uchun = email; google uchun = Google "sub"

  createdAt DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

/// Refresh tokenlarni saqlaydi (xom token emas — hash). Har bir qurilma/sessiya uchun alohida yozuv,
/// shu orqali "barcha sessiyalarni bekor qilish" (parolni tiklashda) va logout mumkin bo'ladi.
model Session {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String   @unique
  userAgent        String?
  ipAddress        String?
  revoked          Boolean  @default(false)
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  @@index([userId])
  @@map("sessions")
}

/// Profil sahifasi uchun ma'lumotlar (6-funksiya, "Profil Sahifasi"da to'liq ishlatiladi;
/// V1 auth bosqichida faqat User bilan birga bo'sh Profile yaratiladi).
model Profile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarUrl       String?
  bannerUrl       String?
  bio             String? // Frontend/DTO darajasida 280 belgi bilan cheklanadi
  aiTools         String[] @default([])
  reputationScore Int      @default(0) // Cron job orqali keyinroq hisoblanadi (PRD 1.4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}

/// Parolni tiklash (Forgot/Reset password) uchun bir martalik tokenlar (PRD 1.3.4).
model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}